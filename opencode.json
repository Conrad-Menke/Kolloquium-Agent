{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": false,
    "bash": {
      ".": [
        "python skills/kolloquium/scripts/index_corpus.py *",
        "python skills/kolloquium/scripts/retrieve.py *",
        "python3 skills/kolloquium/scripts/index_corpus.py *",
        "python3 skills/kolloquium/scripts/retrieve.py *",
        "skills/kolloquium/scripts/.venv/bin/python skills/kolloquium/scripts/index_corpus.py *",
        "skills/kolloquium/scripts/.venv/bin/python skills/kolloquium/scripts/retrieve.py *",
        "pip install -r skills/kolloquium/scripts/requirements.txt",
        "skills/kolloquium/scripts/.venv/bin/pip install -r skills/kolloquium/scripts/requirements.txt",
        "python -m venv skills/kolloquium/scripts/.venv",
        "source skills/kolloquium/scripts/.venv/bin/activate"
      ]
    }
  }
}
